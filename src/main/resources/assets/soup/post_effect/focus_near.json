{
    "targets": {
        "0": {},
        "base": {
            "persistent": true
        }
    },
    "custom_chains": {
        "souper_secret_settings:before_layer_render": [
            {
                "vertex_shader": "minecraft:core/screenquad",
                "fragment_shader": "minecraft:post/blit",
                "inputs": [
                    {
                        "sampler_name": "In",
                        "target": "minecraft:main"
                    }
                ],
                "output": "base",
                "uniforms": {
                    "BlitConfig": [
                        {
                            "name": "ColorModulate",
                            "type": "vec4",
                            "value": [ 1.0, 1.0, 1.0, 1.0 ]
                        }
                    ]
                }
            }
        ],
        "souper_secret_settings:after_layer_render": [
            {
                "vertex_shader": "minecraft:core/screenquad",
                "fragment_shader": "soup:post/depth",
                "inputs": [
                    {
                        "sampler_name": "In",
                        "target": "minecraft:main"
                    },
                    {
                        "sampler_name": "InDepth",
                        "target": "minecraft:main",
                        "use_depth_buffer": true
                    },
                    {
                        "sampler_name": "Base",
                        "target": "base"
                    }
                ],
                "output": "0",
                "uniforms": {
                    "DepthConfig": [
                        {
                            "name": "Scale",
                            "type": "float",
                            "value": 3
                        },
                        {
                            "name": "Offset",
                            "type": "float",
                            "value": 0
                        },
                        {
                            "name": "Clipping",
                            "type": "vec2",
                            "value": [ 0.05, 750 ],
                            "override": "luminance:clipping"
                        }
                    ]
                }
            },
            {
                "vertex_shader": "minecraft:core/screenquad",
                "fragment_shader": "minecraft:post/blit",
                "inputs": [
                    {
                        "sampler_name": "In",
                        "target": "0"
                    }
                ],
                "output": "minecraft:main",
                "uniforms": {
                    "BlitConfig": [
                        {
                            "name": "ColorModulate",
                            "type": "vec4",
                            "value": [ 1.0, 1.0, 1.0, 1.0 ]
                        }
                    ]
                }
            }
        ]
    }
}