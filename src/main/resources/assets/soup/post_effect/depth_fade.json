{
    "targets": {
        "0": {},
        "base": {
            "persistent": true
        }
    },
    "custom_passes": {
        "souper_secret_settings:before_layer_render": [
            {
                "vertex_shader": "minecraft:core/screenquad",
                "fragment_shader": "minecraft:post/blit",
                "inputs": [
                    {
                        "sampler_name": "In",
                        "target": "minecraft:main"
                    }
                ],
                "output": "base",
                "uniforms": {
                    "BlitConfig": [
                        {
                            "name": "ColorModulate",
                            "type": "vec4",
                            "value": [ 1.0, 1.0, 1.0, 1.0 ]
                        }
                    ]
                }
            }
        ],
        "souper_secret_settings:after_layer_render": [
            {
                "vertex_shader": "minecraft:core/screenquad",
                "fragment_shader": "luminance:post/depth_mix",
                "inputs": [
                    {
                        "sampler_name": "In",
                        "target": "base"
                    },
                    {
                        "sampler_name": "InDepth",
                        "target": "minecraft:main",
                        "use_depth_buffer": true
                    },
                    {
                        "sampler_name": "Mix",
                        "target": "minecraft:main"
                    }
                ],
                "uniforms": {
                    "DepthMixConfig": [
                        {
                            "name": "Amount",
                            "type": "vec2",
                            "value": [ 0.6, 0.8 ]
                        },
                        {
                            "name": "ViewDistance",
                            "type": "float",
                            "value": 12.0,
                            "override": "luminance:view_distance"
                        }
                    ]
                },
                "output": "0"
            },
            {
                "vertex_shader": "minecraft:core/screenquad",
                "fragment_shader": "minecraft:post/blit",
                "inputs": [
                    {
                        "sampler_name": "In",
                        "target": "0"
                    }
                ],
                "output": "minecraft:main",
                "uniforms": {
                    "BlitConfig": [
                        {
                            "name": "ColorModulate",
                            "type": "vec4",
                            "value": [ 1.0, 1.0, 1.0, 1.0 ]
                        }
                    ]
                }
            }
        ]
    }
}