{
    "targets": {
        "0": {},
        "previous": {
            "persistent": true
        }
    },
    "custom_chains": {
        "souper_secret_settings:before_layer_render": [
            {
                "vertex_shader": "minecraft:core/screenquad",
                "fragment_shader": "soup:post/out_of_bounds",
                "inputs": [
                    {
                        "sampler_name": "In",
                        "target": "minecraft:main"
                    },
                    {
                        "sampler_name": "InDepth",
                        "target": "minecraft:main",
                        "use_depth_buffer": true
                    },
                    {
                        "sampler_name": "PrevOut",
                        "target": "previous"
                    }
                ],
                "uniforms": {
                    "OutOfBoundsConfig": [
                        {
                            "name": "Threshold",
                            "type": "float",
                            "value": -100
                        },
                        {
                            "name": "Color",
                            "type": "vec3",
                            "value": [ 0.0, 0.0, 0.0 ]
                        },
                        {
                            "name": "Pixels",
                            "type": "vec2",
                            "value": [ 0, 1 ]
                        },
                        {
                            "name": "Requirements",
                            "type": "float",
                            "value": -1
                        },
                        {
                            "name": "Offset",
                            "type": "vec2",
                            "value": [ 0, -10 ]
                        },
                        {
                            "name": "Amount",
                            "type": "vec3",
                            "value": [ 1.0, 1.0, 1.0 ]
                        },
                        {
                            "name": "Clipping",
                            "type": "vec2",
                            "value": [ 0.05, 750 ],
                            "override": "luminance:clipping"
                        }
                    ]
                },
                "output": "0"
            },
            {
                "vertex_shader": "minecraft:core/screenquad",
                "fragment_shader": "minecraft:post/blit",
                "inputs": [
                    {
                        "sampler_name": "In",
                        "target": "0"
                    }
                ],
                "output": "minecraft:main",
                "uniforms": {
                    "BlitConfig": [
                        {
                            "name": "ColorModulate",
                            "type": "vec4",
                            "value": [ 1.0, 1.0, 1.0, 1.0 ]
                        }
                    ]
                }
            }
        ],
        "souper_secret_settings:after_layer_render": [
            {
                "vertex_shader": "minecraft:core/screenquad",
                "fragment_shader": "minecraft:post/blit",
                "inputs": [
                    {
                        "sampler_name": "In",
                        "target": "minecraft:main"
                    }
                ],
                "output": "previous",
                "uniforms": {
                    "BlitConfig": [
                        {
                            "name": "ColorModulate",
                            "type": "vec4",
                            "value": [ 1.0, 1.0, 1.0, 1.0 ]
                        }
                    ]
                }
            }
        ]
    }
}